# IGRIS Mobile App Configuration
# Set these environment variables when building the app

# Backend URL for the IGRIS API
# For development with Android emulator: http://10.0.2.2:8080/api
# For development with iOS simulator: http://localhost:8080/api
# For production: https://your-domain.com/api
IGRIS_BACKEND_URL=http://10.0.2.2:8080/api

# ────────────────────────────────────────────────────────────────────────────
# Picovoice Porcupine (on-device wake word "Hey IGRIS")
# ────────────────────────────────────────────────────────────────────────────
# Get a free AccessKey at https://console.picovoice.ai/
# DO NOT hardcode this value in source. Pass at build time:
#   flutter build apk --dart-define=PICOVOICE_ACCESS_KEY=YOUR_KEY_HERE
# At runtime the key is moved into flutter_secure_storage; never logged.
# The key is bound to your Picovoice account and used to verify the .ppn model.
PICOVOICE_ACCESS_KEY=

# Optional override for the .ppn model path. Default uses the bundled asset
# at assets/wake_word/Hey-IGRIS_android.ppn (or _ios.ppn on iOS).
IGRIS_WAKE_WORD_MODEL=assets/wake_word/Hey-IGRIS_android.ppn

# Example build commands:
# flutter build apk --dart-define=IGRIS_BACKEND_URL=https://your-production-domain.com/api \
#                   --dart-define=PICOVOICE_ACCESS_KEY=YOUR_KEY
# flutter run --dart-define=IGRIS_BACKEND_URL=http://10.0.2.2:8080/api \
#             --dart-define=PICOVOICE_ACCESS_KEY=YOUR_KEY