# IGRIS Backend — Environment Variables Template
# Rule #1: Copy this file to .env and fill in real values. NEVER commit .env to git.
#
# Generate strong secrets with:  openssl rand -hex 32

PORT=5000
NODE_ENV=production

# Rule #6 — CORS: set your actual frontend domain, never use *
CORS_ORIGIN=https://your-frontend-domain.com

# Database (production = postgres on Supabase)
DB_DIALECT=postgres
DB_HOST=db.your-project-ref.supabase.co
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_supabase_db_password

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Rule #4 — JWT secrets: min 32 chars random string
JWT_SECRET=
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRES_IN=7d

# AI Keys (server-side ONLY — Rule #1, Rule AI/LLM)
GEMINI_API_KEY_DEFAULT=
MURF_API_KEY_DEFAULT=

# Telegram
TELEGRAM_BOT_TOKEN=
# Public username of the Telegram bot (no leading @). The mobile app uses this
# to build https://t.me/<username>?start=link_<jwt> deep links. This is a
# publishable identifier — it is safe to embed in the mobile client.
TELEGRAM_BOT_USERNAME=your_telegram_bot_username
# Optional: dedicated secret for the one-time Telegram-link JWT. If unset, the
# backend falls back to JWT_SECRET. The Python bot (telegram_bot/) must use
# the same value to verify link tokens it receives.
TELEGRAM_LINK_SECRET=
# TTL for the one-time Telegram-link JWT. Keep short.
TELEGRAM_LINK_EXPIRES_IN=15m

# Email
SENDGRID_API_KEY=
EMAIL_FROM=IGRIS <noreply@igris.ai>

# Twilio / WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Rule #8 — File size limit: 5MB
MAX_FILE_SIZE=5242880

# Logging
LOG_LEVEL=info

# Google Custom Search (for web_search tool)
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# RAG (Retrieval Augmented Generation) Configuration
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5
RAG_EMBEDDING_MODEL=text-embedding-004

# LangChain Configuration
LANGCHAIN_MAX_ITERATIONS=10
LANGCHAIN_VERBOSE=false